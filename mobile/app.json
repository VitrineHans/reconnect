{
  "expo": {
    "name": "Reconnect",
    "slug": "reconnect",
    "scheme": "reconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hanswagener.reconnect",
      "infoPlist": {
        "NSCameraUsageDescription": "Reconnect uses your camera to record video answers.",
        "NSMicrophoneUsageDescription": "Reconnect uses your microphone to record video answers.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.hanswagener.reconnect",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-video",
      "expo-localization",
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "47113044-85f7-40e2-9e70-4fa2a4f9aa21"
      }
    },
    "owner": "hwagener"
  }
}
